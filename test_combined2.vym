export class Context:
    client_fd: Float64
    raw_req: Dict<String, String>
    method: String
    path: String
    body: String
    
    // In Vyauma v1/v2, constructors cannot take arguments natively, but since we are using `new Class()` it might just work if we set properties after creation.
    // Actually, Vyauma uses `new Class(args)` and transforms it to `StructInit`. Wait, no, `StructInit` doesn't take positional arguments for `Class` initialization, wait, let me just set fields manually.
    


    fn send_json(json_str: String):
        self.send_json_status(json_str, 200.0)
        
    fn send_json_status(json_str: String, status: Float64):
        let mut status_str = "200 OK"
        if status == 404.0:
            status_str = "404 Not Found"
        else:
            if status == 500.0:
                status_str = "500 Internal Server Error"
        
        let header = "HTTP/1.1 " + status_str + "\r\nContent-Type: application/json\r\n\r\n"
        let full_response = header + json_str
        
        let bytes = string_to_bytes(full_response)
        write(self.client_fd, bytes)

export fn new_context(fd: Float64, req: Dict<String, String>) -> Context:
    let method = req["method"]
    let path = req["path"]
    let body = req["body"]
    let c = new Context(fd, req, method, path, body)
    return c

export class Router:
    // We will use a Dict for each method, mapping path to a handler name/reference
    // However, Vyauma currently lacks function pointers, so we will use dynamic dispatch via strings and a big match/if block or we can just keep it simple.
    // For now, let's just use a simple list of routes.
    routes_method: Array<String>
    routes_path: Array<String>
    
    // In a real framework we'd pass a closure or function pointer.
    // For now we'll just print the matching route and return a mock response.
    

    fn get(path: String):
        ffi_array_push(self.routes_method, "GET")
        ffi_array_push(self.routes_path, path)
        
    fn post(path: String):
        ffi_array_push(self.routes_method, "POST")
        ffi_array_push(self.routes_path, path)

    fn route(ctx: Context):
        let mut i = 0.0
        let len = ffi_array_len(self.routes_path)
        let mut matched = false
        
        while i < len:
            if self.routes_method[i] == ctx.method:
                if self.routes_path[i] == ctx.path:
                    matched = true
                    // Call handler (mocked)
                    ffi_console_println("Matched route: " + ctx.method + " " + ctx.path)
                    ctx.send_json("{\"status\":\"success\", \"message\":\"Route matched!\"}")
                    return
            i = i + 1.0
            
        if matched == false:
            ctx.send_json_status("{\"error\":\"Not Found\"}", 404.0)

export fn new_router() -> Router:
    let rm: Array<String> = []
    let rp: Array<String> = []
    let r = new Router(rm, rp)
    return r
// HTTP Module

export fn get(url: String) -> String:
    return ffi_http_get(url)

export fn post(url: String, body: String) -> String:
    return ffi_http_post(url, body)

// Parses a raw HTTP request string into a Vyauma Dictionary
export fn parse_request(raw_string: String) -> Dict<String, String>:
    let parts = ffi_string_split(raw_string, "\r\n\r\n")
    let mut req: Dict<String, String> = { "method": "INVALID" }
    
    if ffi_array_len(parts) < 2:
        return req
    
    let headers_part = parts[0]
    let body_part = parts[1]
    
    let lines = ffi_string_split(headers_part, "\r\n")
    if ffi_array_len(lines) < 1:
        return req
    
    let first_line = lines[0]
    let request_line = ffi_string_split(first_line, " ")
    if ffi_array_len(request_line) < 2:
        return req
    
    req["method"] = request_line[0]
    req["path"] = request_line[1]
    req["body"] = body_part
    
    return req




export class Server:
    port: Float64
    r: Router

    fn start():
        let server_fd = net_listen(self.port)
        ffi_console_println("VWF Server listening on port: " + self.port)
        
        while true:
            let client_fd = net_accept(server_fd)
            if client_fd >= 0.0:
                self.handle_client(client_fd)

    fn handle_client(client_fd: Float64):
        let buf: Array<Float64> = []
        let mut i = 0.0
        while i < 1024.0:
            ffi_array_push(buf, 0.0)
            i = i + 1.0
            
        let mut bytes_read = 0.0 - 1.0
        let mut attempts = 0.0
        while bytes_read < 0.0:
            bytes_read = read(client_fd, buf)
            if bytes_read < 0.0:
                ffi_task_sleep(10.0)
                attempts = attempts + 1.0
                if attempts > 100.0:
                    // Timeout after 1 second
                    close(client_fd)
                    return
                    
        if bytes_read > 0.0:
            let req_str = bytes_to_string(buf)
            let raw_req = parse_request(req_str)
            
            let ctx = new_context(client_fd, raw_req)
            self.r.route(ctx)
        
        close(client_fd)

export fn new_server(port: Float64, r: Router) -> Server:
    let s = new Server(port, r)
    return s

export fn main():
    ffi_console_println("Starting combined server...")
    let r = new_router()
    r.get("/api/health")
    let s = new_server(8080.0, r)
    s.start()

