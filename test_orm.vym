import "./vyauma_modules/db/index.vym" as db

class User:
    id: Float64
    name: String
    email: String

fn main():
    // 1. Connect to in-memory SQLite database
    let database = db::connect("sqlite", "sqlite::memory:")
    
    // 2. Setup Schema manually
    let empty_params: Array<String> = []
    database.execute("CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT)", empty_params)
    
    // 3. Create Model mapping
    let UserModel = db::new_model(database, "users")
    
    // 4. Insert data using dictionary mapping
    let payload = { "name": "Manvirr", "email": "manvirr@example.com" }
    ffi_console_println("Payload name: " + payload["name"])
    let affected = UserModel.create(payload)
    
    // 5. Query data
    let params: Array<String> = ["Manvirr"]
    let users = UserModel.where_query("name = ?", params)
    
    let empty_params2: Array<String> = []
    let all_users = UserModel.where_query("1=1", empty_params2)
    
    ffi_console_println("Affected rows: " + affected)
    ffi_console_println("Users found: " + ffi_array_len(users))
    ffi_console_println("All users found: " + ffi_array_len(all_users))
    
    // Dump users
    ffi_console_println("Query result: " + users)
    ffi_console_println("All users: " + all_users)
    
    let first_user = all_users[0]
    ffi_console_println("First user: " + first_user)
    ffi_console_println("First user name: " + first_user["name"])
