// Math utilities wrapping native FFI

export fn pi() -> Float64 {
    return ffi_math_pi();
}

export fn sqrt(x: Float64) -> Float64 {
    return ffi_math_sqrt(x);
}

export fn pow(base: Float64, exp: Float64) -> Float64 {
    return ffi_math_pow(base, exp);
}

export fn log(x: Float64) -> Float64 {
    return ffi_math_log(x);
}
