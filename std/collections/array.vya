// Array utilities wrapping native FFI

export fn push(arr: Any, val: Any) -> Any {
    return ffi_array_push(arr, val);
}

export fn pop(arr: Any) -> Any {
    return ffi_array_pop(arr);
}

export fn len(arr: Any) -> Float64 {
    return ffi_array_len(arr);
}

export fn get(arr: Any, index: Float64) -> Any {
    return ffi_array_get(arr, index);
}

export fn set(arr: Any, index: Float64, val: Any) -> Any {
    return ffi_array_set(arr, index, val);
}
