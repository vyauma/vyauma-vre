export fn math_abs(x: Float64) -> Float64 { return ffi_math_abs(x); }
export fn math_floor(x: Float64) -> Float64 { return ffi_math_floor(x); }
export fn math_ceil(x: Float64) -> Float64 { return ffi_math_ceil(x); }
export fn math_round(x: Float64) -> Float64 { return ffi_math_round(x); }
export fn math_sin(x: Float64) -> Float64 { return ffi_math_sin(x); }
export fn math_cos(x: Float64) -> Float64 { return ffi_math_cos(x); }
export fn math_tan(x: Float64) -> Float64 { return ffi_math_tan(x); }
export fn math_sqrt(x: Float64) -> Float64 { return ffi_math_sqrt(x); }
export fn math_pow(x: Float64, y: Float64) -> Float64 { return ffi_math_pow(x, y); }
